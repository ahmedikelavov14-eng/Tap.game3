<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Moy Tap Premium</title>
    <script src="https://telegram.org"></script>
    <style>
        body {
            background: radial-gradient(circle at center, #1e3a8a 0%, #0f172a 100%);
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        /* Анимированные частицы на фоне */
        .bg-glow {
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(59, 130, 246, 0.2);
            filter: blur(100px);
            border-radius: 50%;
            z-index: -1;
            animation: pulseBg 8s infinite alternate;
        }

        @keyframes pulseBg {
            0% { transform: scale(1); opacity: 0.5; }
            100% { transform: scale(1.5); opacity: 0.8; }
        }

        #score-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 10px 30px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        #score {
            font-size: 56px;
            font-weight: 800;
            background: linear-gradient(to bottom, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
        }

        .coin-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            perspective: 1000px;
        }

        #coin {
            width: 260px;
            height: 260px;
            background: linear-gradient(135deg, #ffd700 0%, #ff8c00 50%, #b8860b 100%);
            border-radius: 50%;
            position: relative;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 
                0 0 0 10px rgba(255, 215, 0, 0.2),
                0 20px 50px rgba(0, 0, 0, 0.5),
                inset 0 -8px 15px rgba(0, 0, 0, 0.3),
                inset 0 8px 15px rgba(255, 255, 255, 0.6);
            transition: transform 0.05s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 4px solid #facc15;
        }

        /* Блик на монете */
        #coin::before {
            content: '';
            position: absolute;
            top: 10%;
            left: 15%;
            width: 70%;
            height: 30%;
            background: linear-gradient(to bottom, rgba(255,255,255,0.4) 0%, transparent 100%);
            border-radius: 50%;
        }

        /* Центральный логотип */
        #coin-inner {
            font-size: 110px;
            filter: drop-shadow(0 4px 4px rgba(0,0,0,0.3));
        }

        #coin:active {
            transform: scale(0.92) rotateX(10deg);
        }

        .tap-text {
            position: absolute;
            font-size: 32px;
            font-weight: 900;
            color: #fbbf24;
            pointer-events: none;
            z-index: 10;
            animation: floatUp 0.7s ease-out forwards;
            text-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        @keyframes floatUp {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-150px) scale(1.5); opacity: 0; }
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>
    
    <div id="score-container">
        <div id="score">0</div>
    </div>

    <div class="coin-wrapper">
        <div id="coin">
            <div id="coin-inner">🪙</div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        const coin = document.getElementById('coin');
        const scoreElement = document.getElementById('score');
        
        let score = parseInt(localStorage.getItem('tapScorePremium')) || 0;
        scoreElement.textContent = score;

        tg.expand();
        tg.headerColor = '#1e3a8a';

        coin.addEventListener('pointerdown', (e) => {
            score++;
            scoreElement.textContent = score;
            localStorage.setItem('tapScorePremium', score);

            // Вибрация
            if (tg.HapticFeedback) {
                tg.HapticFeedback.impactOccurred('medium');
            }

            // Анимация текста +1
            createFloatingText(e.clientX, e.clientY);
        });

        function createFloatingText(x, y) {
            const text = document.createElement('div');
            text.className = 'tap-text';
            text.textContent = '+1';
            text.style.left = (x - 20) + 'px';
            text.style.top = (y - 40) + 'px';
            document.body.appendChild(text);

            setTimeout(() => text.remove(), 700);
        }
    </script>
</body>
</html>


